<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pra.Profile"
             Title="Profile">
    <Grid RowDefinitions="Auto,*,Auto">

        <Grid Grid.Row="0"
              BackgroundColor="#40C95A"
              HeightRequest="90"
              Padding="20,15">

            <Image Source="logo.png"
                   HeightRequest="50"
                   HorizontalOptions="Start"
                   VerticalOptions="Center" />

            <Label Text="Профиль"
                   TextColor="White"
                   FontSize="32"
                   FontAttributes="Bold"
                   FontFamily="Finlandica"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>


        <ScrollView Grid.Row="1">

            <VerticalStackLayout Padding="20"
                                 Spacing="25">

                <Border Padding="20"
                        BackgroundColor="White"
                        StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Opacity="0.08"
                                Radius="18"
                                Offset="0,6"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="16">

                        <Border WidthRequest="64"
                                HeightRequest="64"
                                BackgroundColor="#40C95A"
                                StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="32"/>
                            </Border.StrokeShape>

                            <Label Text="П"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="4">

                            <Label Text="Имя пользователя"
                                   FontSize="20"
                                   FontFamily="Finlandica"
                                   TextColor="#1F2937"
                                   FontAttributes="Bold"/>

                            <Label Text="Уровень: Inter"
                                   FontSize="16"
                                   FontFamily="Finlandica"
                                   TextColor="#40C95A"/>
                        </VerticalStackLayout>

                    </Grid>
                </Border>


                <Border BackgroundColor="White"
                        StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Opacity="0.08"
                                Radius="18"
                                Offset="0,6"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">

                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto">

                            <Label Text="Изучаемый язык"
                                   FontSize="16"
                                   FontFamily="Finlandica"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>

                            <Picker Grid.Column="1"
                                    WidthRequest="150"
                                    TextColor="#40C95A">

                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Английский</x:String>
                                        <x:String>Немецкий</x:String>
                                        <x:String>Французский</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#E5E7EB"/>

                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="10">

                            <Label Text="Ежедневная цель"
                                   FontSize="16"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>

                            <Label Grid.Column="1"
                                   Text="20 слов"
                                   FontSize="16"
                                   TextColor="#40C95A"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>

                            <Stepper Grid.Column="2"
                                     Minimum="5"
                                     Maximum="100"
                                     Increment="5"
                                     Value="20"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#E5E7EB"/>

                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto">

                            <Label Text="Уведомления"
                                   FontSize="16"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>

                            <Switch Grid.Column="1"
                                    IsToggled="False"
                                    OnColor="#40C95A"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#E5E7EB"/>

                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto">

                            <Label Text="Темная тема"
                                   FontSize="16"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>

                            <Switch Grid.Column="1"
                                    IsToggled="False"
                                    OnColor="#40C95A"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>


                <Button Text="Сбросить прогресс"
                        BackgroundColor="#40C95A"
                        TextColor="White"
                        CornerRadius="32"
                        HeightRequest="60"
                        FontSize="18"
                        FontAttributes="Bold"
                        FontFamily="Finlandica"/>

            </VerticalStackLayout>
        </ScrollView>


        <Border Grid.Row="2"
        BackgroundColor="#40C95A"
        StrokeThickness="0"
        Padding="10,15">

            <Border.Shadow>
                <Shadow Brush="Black"
                Opacity="0.08"
                Radius="10"
                Offset="0,-2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*">

                <VerticalStackLayout Grid.Column="0"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUrokTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Уроки"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Профиль"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>


                <VerticalStackLayout Grid.Column="2"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStaticTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Статистика"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>


                <VerticalStackLayout Grid.Column="3"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSlovarTapped" />
                    </VerticalStackLayout.GestureRecognizers>


                    <Label Text="Словарь"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>



                <VerticalStackLayout Grid.Column="4"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDostigTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Достижения"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>

            </Grid>

        </Border>

    </Grid>
</ContentPage>