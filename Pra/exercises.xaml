<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pra.exercises"
             Title="Упражнения">

    <Grid RowDefinitions="Auto, *, Auto">
        <!--шапка-->
        <Grid Grid.Row="0"
              BackgroundColor="#40C95A"
              HeightRequest="90"
              Padding="20,15">
            <Image Source="logo.png"
                   HeightRequest="50"
                   HorizontalOptions="Start"
                   VerticalOptions="Center"/>
            <Label Text="Упражнения"
                   TextColor="White"
                   FontSize="32"
                   FontAttributes="Bold"
                   FontFamily="Finlandica"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>
        <!--Тест-->
        <Grid x:Name="QuizView"
              Grid.Row="1"
              RowDefinitions="Auto,Auto,Auto,*" RowSpacing="18"
              Padding="20">
            <!--Прогресс теста-->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="12">
                <ProgressBar x:Name="TestProgress" Progress="0"
                             ProgressColor="{StaticResource LightGreen}"
                             VerticalOptions="Center" HeightRequest="10"/>
                <Label x:Name="CounterLabel"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Dark}"
                       VerticalOptions="Center"/>
            </Grid>
            <!--задание-->
            <Border Grid.Row="1" BackgroundColor="{StaticResource Emerald}"
                    StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="18">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Соберите предложение" FontSize="13"
                           TextColor="{StaticResource Cream}" Opacity="0.85"/>
                    <Label x:Name="PromptLabel" Text="" FontSize="22"
                           FontAttributes="Bold" TextColor="{StaticResource Cream}"/>
                </VerticalStackLayout>
            </Border>
            <!--зона для ответа-->
            <Border Grid.Row="2" BackgroundColor="White"
                    StrokeShape="RoundRectangle 16"
                    Stroke="LightGray"
                    StrokeThickness="1"
                    Padding="8" MinimumHeightRequest="100">
                <FlexLayout x:Name="AnswerArea" Wrap="Wrap"
                            AlignItems="Start" AlignContent="Start"
                            Direction="Row"/>
            </Border>
             <!--хранение слов-->
            <ScrollView Grid.Row="3">
                <FlexLayout x:Name="WordsKeep" Wrap="Wrap" Direction="Row"
                            AlignItems="Center" AlignContent="Start"/>
            </ScrollView>
            <!--итог и кнопка проверки ответа-->
            <VerticalStackLayout x:Name="BottomBar" Grid.Row="2"
                                 Padding="20,0,20,20"
                                 Spacing="12">
                <Border x:Name="Banner" IsVisible="False"
                        StrokeShape="RoundRectangle 14"
                        Stroke="Transparent"
                        Padding="14,12">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="Title" Text="" FontSize="15" FontAttributes="Bold"/>
                        <Label x:Name="Detail" Text="" FontSize="15" FontAttributes="Bold" IsVisible="False"/>
                        <Label x:Name="Explain" Text="" FontSize="15" IsVisible="False" Opacity="0.9" Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Border>
                <Button x:Name="CheckButton" Text="Проверить"
                        BackgroundColor="{StaticResource LightGreen}"
                        TextColor="{StaticResource Dark}"
                        CornerRadius="16" HeightRequest="54"
                        FontAttributes="Bold"
                        IsEnabled="False" Clicked="CheckButton_Clicked"/>
            </VerticalStackLayout>
            <!--Резульат упражнений-->
            <VerticalStackLayout x:Name="ResultView" Grid.Row="1" IsVisible="False"
                                 VerticalOptions="Center" Padding="20" Spacing="16">
                <Label x:Name="ResultEmoji" Text="🎉" FontSize="64"
                       HorizontalOptions="Center"/>
                <Label Text="Все упраженения выролнены!" FontSize="24" FontAttributes="Bold"
                       TextColor="{StaticResource Dark}" HorizontalOptions="Center"/>
                <Border BackgroundColor="{StaticResource Emerald}"
                        StrokeShape="RoundRectangle 20" Stroke="Transparent"
                        Padding="20,30" HorizontalOptions="Center">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="ResultScore" Text="0 / 20" FontSize="40"
                               FontAttributes="Bold" TextColor="{StaticResource Cream}"
                               HorizontalOptions="Center"/>
                        <Label x:Name="ResultPercent" Text="" FontSize="14"
                               TextColor="{StaticResource Cream}" Opacity="0.85"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Button Text="Пройти заново"
                        BackgroundColor="{StaticResource LightGreen}"
                        TextColor="{StaticResource Dark}"
                        CornerRadius="16" HeightRequest="54"
                        FontAttributes="Bold"
                        WidthRequest="220" Clicked="Button_Clicked"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>