<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pra.Profile"
             Title="Profile">

    <Grid RowDefinitions="Auto,*,Auto">

        <Grid Grid.Row="0"
              BackgroundColor="#40C95A"
              HeightRequest="90"
              Padding="20,15">

            <Image Source="logo.png"
                   HeightRequest="50"
                   HorizontalOptions="Start"
                   VerticalOptions="Center" />

            <Label Text="Профиль"
                   TextColor="White"
                   FontSize="32"
                   FontAttributes="Bold"
                   FontFamily="Finlandica"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="25">

                <Border Padding="20"
                        BackgroundColor="White"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Opacity="0.08"
                                Radius="18"
                                Offset="0,6"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="16">

                        <Border WidthRequest="80"
                                HeightRequest="80"
                                BackgroundColor="#E5E7EB"
                                StrokeThickness="2"
                                Stroke="#40C95A">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="40"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                            </Border.GestureRecognizers>

                            <Grid>
                                <Image x:Name="AvatarImage"
                                       Source="user_placeholder.png"
                                       Aspect="AspectFill"
                                       WidthRequest="76"
                                       HeightRequest="76"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>

                                <Border BackgroundColor="#40C95A"
                                        WidthRequest="24"
                                        HeightRequest="24"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        StrokeThickness="0"
                                        Margin="0,0,4,4">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="✏️"
                                           FontSize="12"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="4">
                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                                <Label x:Name="UserNameLabel"
                                       Grid.Column="0"
                                       Text="Имя пользователя"
                                       FontSize="20"
                                       FontFamily="Finlandica"
                                       TextColor="#1F2937"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       />
                                
                                <Button Grid.Column="1"
                                        Text="✏️"
                                        BackgroundColor="Transparent"
                                        TextColor="#40C95A"
                                        FontSize="16"
                                        Clicked="OnEditNameClicked"
                                        Padding="0"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        VerticalOptions="Center"/>
                            </Grid>
                            <Label x:Name="LevelLabel"
                                   Text="Уровень: Beginner"
                                   FontSize="16"
                                   FontFamily="Finlandica"
                                   TextColor="#40C95A"/>
                            <Label x:Name="WordsLabel"
                                   Text="📚 0 слов изучено"
                                   FontSize="14"
                                   FontFamily="Finlandica"
                                   TextColor="#6B7280"/>
                        </VerticalStackLayout>

                       
                        <Button Grid.Column="2"
                                Text="Выйти"
                                BackgroundColor="#FEE2E2"
                                TextColor="#EF4444"
                                CornerRadius="20"
                                FontSize="14"
                                VerticalOptions="Center"
                                Clicked="OnLogoutClicked"/>
                    </Grid>
                </Border>

                <Border BackgroundColor="White"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Opacity="0.08"
                                Radius="18"
                                Offset="0,6"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">
                       
                       
                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto">
                            <Label Text="Изучаемый язык"
                                   FontSize="16"
                                   FontFamily="Finlandica"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>
                            <Picker Grid.Column="1"
                                    x:Name="LanguagePicker"
                                    WidthRequest="150"
                                    TextColor="#40C95A"
                                    SelectedIndexChanged="OnLanguageChanged">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Английский</x:String>
                                        <x:String>Немецкий</x:String>
                                        <x:String>Французский</x:String>
                                        <x:String>Испанский</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#E5E7EB"/>

                        
                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="10">
                            <Label Text="Ежедневная цель"
                                   FontSize="16"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="10"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center">
                                <Button Text="-"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        Padding="0"
                                        BackgroundColor="#E8F8D5"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        Clicked="OnGoalMinus"/>
                                <Label x:Name="GoalLabel"
                                       Grid.Column="1"
                                       Text="20 слов"
                                       FontSize="16"
                                       TextColor="#40C95A"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                                <Button Text="+"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        Padding="0"
                                        BackgroundColor="#40C95A"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        Clicked="OnGoalPlus"/>
                            </HorizontalStackLayout>
                            
                        </Grid>

                        <BoxView HeightRequest="1" Color="#E5E7EB"/>

                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto">
                            <Label Text="Уведомления"
                                   FontSize="16"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="1"
                                    x:Name="NotificationSwitch"
                                    IsToggled="False"
                                    OnColor="#40C95A"
                                    HorizontalOptions="End"
                                    Margin="0,0,-30,0"
                                    Toggled="OnNotificationToggled"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#E5E7EB"/>

                        <Grid Padding="16"
                              ColumnDefinitions="*,Auto">
                            <Label Text="Темная тема"
                                   FontSize="16"
                                   TextColor="#1F2937"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="1"
                                    x:Name="DarkThemeSwitch"
                                    IsToggled="False"
                                    OnColor="#40C95A"
                                    HorizontalOptions="End"
                                    Margin="0,0,-30,0"
                                    Toggled="OnDarkThemeToggled"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Сбросить прогресс"
                        BackgroundColor="#40C95A"
                        TextColor="White"
                        CornerRadius="32"
                        HeightRequest="60"
                        FontSize="18"
                        FontAttributes="Bold"
                        FontFamily="Finlandica"
                        Clicked="OnResetProgressClicked"/>

            </VerticalStackLayout>
        </ScrollView>

        
        <Border Grid.Row="2"
                BackgroundColor="#40C95A"
                StrokeThickness="0"
                Padding="10,15">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.08"
                        Radius="10"
                        Offset="0,-2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*,*">
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="4"
                                     HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUrokTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Уроки"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Профиль"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2"
                                     Spacing="4"
                                     HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStaticTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Статистика"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3"
                                     Spacing="4"
                                     HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSlovarTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Словарь"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4"
                                     Spacing="4"
                                     HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDostigTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Достижения"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="5" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPovtorTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Повторение"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>