<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pra.NewPage2"
             Title="NewPage2">

    <Grid RowDefinitions="Auto,*,Auto">

        <Grid Grid.Row="0"
              BackgroundColor="#40C95A"
              HeightRequest="90"
              Padding="20,15">

            <Label Text="Достижения"
                   TextColor="White"
                   FontSize="32"
                   FontAttributes="Bold"
                   FontFamily="Finlandica"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>


        <ScrollView Grid.Row="1">

            <VerticalStackLayout Padding="20"
                                 Spacing="16">

                <Label Text="Твои награды 🏅"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1F2937"/>

                <Border BackgroundColor="White"
                        Padding="16"
                        StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Opacity="0.08"
                                Radius="15"
                                Offset="0,5"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*">

                        <Label Text="🥇"
                               FontSize="40"
                               VerticalOptions="Center"/>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4">

                            <Label Text="Первые 100 слов"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#1F2937"/>

                            <Label Text="Ты выучил 100 слов"
                                   FontSize="14"
                                   TextColor="#6B7280"/>

                            <Label Text="Выполнено"
                                   FontSize="13"
                                   TextColor="#40C95A"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>

                    </Grid>
                </Border>

                <Border BackgroundColor="White"
                        Padding="16"
                        StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Opacity="0.08"
                                Radius="15"
                                Offset="0,5"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*">

                        <Label Text="🔥"
                               FontSize="40"
                               VerticalOptions="Center"/>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4">

                            <Label Text="Серия 7 дней"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#1F2937"/>

                            <Label Text="Занимайся каждый день"
                                   FontSize="14"
                                   TextColor="#6B7280"/>

                            <Label Text="Активно"
                                   FontSize="13"
                                   TextColor="#F59E0B"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>

                    </Grid>
                </Border>

                <Border BackgroundColor="#E5E7EB"
                        Padding="16"
                        StrokeThickness="0"
                        Opacity="0.7">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="Auto,*">

                        <Label Text="🔒"
                               FontSize="40"
                               VerticalOptions="Center"/>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4">

                            <Label Text="Легендарный ученик"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#6B7280"/>

                            <Label Text="Достигни 1000 слов"
                                   FontSize="14"
                                   TextColor="#9CA3AF"/>

                            <Label Text="Заблокировано"
                                   FontSize="13"
                                   TextColor="#6B7280"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>

                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>


        <Border Grid.Row="2"
BackgroundColor="#40C95A"
StrokeThickness="0"
Padding="10,15">

            <Border.Shadow>
                <Shadow Brush="Black"
        Opacity="0.08"
        Radius="10"
        Offset="0,-2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*,*">

                <VerticalStackLayout Grid.Column="0"
                     Spacing="4"
                     HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUrokTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Уроки"
           FontSize="16"
           TextColor="White"
           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                     Spacing="4"
                     HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Профиль"
           FontSize="16"
           TextColor="White"
           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>


                <VerticalStackLayout Grid.Column="2"
                     Spacing="4"
                     HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStaticTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Статистика"
           FontSize="16"
           TextColor="White"
           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>


                <VerticalStackLayout Grid.Column="3"
                     Spacing="4"
                     HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSlovarTapped" />
                    </VerticalStackLayout.GestureRecognizers>


                    <Label Text="Словарь"
           FontSize="16"
           TextColor="White"
           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>



                <VerticalStackLayout Grid.Column="4"
                     Spacing="4"
                     HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDostigTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Достижения"
           FontSize="16"
           TextColor="White"
           HorizontalTextAlignment="Center" />

                </VerticalStackLayout>


                <VerticalStackLayout Grid.Column="5" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPovtorTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Повторение"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>

        </Border>

    </Grid>
    </ContentPage>
