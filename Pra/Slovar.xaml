<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Pra.Slovar"
    BackgroundColor="#F5F7F8">

    <Grid RowDefinitions="Auto,*,Auto">

       

        <Grid Grid.Row="0"
              BackgroundColor="#40C95A"
              HeightRequest="90"
              Padding="20,15">

            <Image Source="logo.png"
                   HeightRequest="50"
                   HorizontalOptions="Start"
                   VerticalOptions="Center" />

            <Label Text="Словарь"
                   TextColor="White"
                   FontSize="32"
                   FontAttributes="Bold"
                   FontFamily="Finlandica"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

        </Grid>

    

        <ScrollView Grid.Row="1">

            <VerticalStackLayout
                Padding="20"
                Spacing="20">


                <Border StrokeThickness="0"
                        BackgroundColor="White"
                        Padding="15">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Opacity="0.08"
                                Radius="12"
                                Offset="0,4"/>
                    </Border.Shadow>

                    <SearchBar x:Name="WordSearchBar"
                               Placeholder="Поиск слова..."
                               SearchCommand="{Binding SearchCommand}"
                               BackgroundColor="Transparent"
                               FontFamily="Finlandica"
                               TextChanged="OnSearchTextChanged"/>
                </Border>
      
                <Button Text="+ Добавить слово"
                        HeightRequest="60"
                        CornerRadius="30"
                        BackgroundColor="#40C95A"
                        TextColor="White"
                        FontSize="22"
                        FontAttributes="Bold"
                        FontFamily="Finlandica"
                        Clicked="OnAddWordClicked"/>


                <CollectionView x:Name="WordsCollection">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="15"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <Border Padding="18"
                                    StrokeThickness="0"
                                    BackgroundColor="White">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="24"/>
                                </Border.StrokeShape>

                                <Border.Shadow>
                                    <Shadow Brush="Black"
                                            Opacity="0.08"
                                            Radius="12"
                                            Offset="0,4"/>
                                </Border.Shadow>

                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto,Auto">


                                    <Label Grid.Row="0"
                                           Grid.Column="0"
                                           Text="{Binding Word}"
                                           FontSize="26"
                                           FontAttributes="Bold"
                                           TextColor="#1F2937"
                                           FontFamily="Finlandica"/>


                                    <Border Grid.Row="0"
                                            Grid.Column="1"
                                            BackgroundColor="#E8F8D5"
                                            Padding="10,4"
                                            Margin="10,0,0,0"
                                            StrokeThickness="0">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>

                                        <Label Text="{Binding Category}"
                                               FontSize="12"
                                               TextColor="#40C95A"/>
                                    </Border>


                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="3"
                                           Margin="0,10,0,0"
                                           Text="{Binding Translation}"
                                           FontSize="20"
                                           TextColor="#6B7280"
                                           FontFamily="Finlandica"/>


                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="3"
                                           Margin="0,5,0,0"
                                           Text="{Binding Transcription}"
                                           FontSize="16"
                                           TextColor="#9CA3AF"
                                           FontAttributes="Italic"/>

                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnWordTapped"/>
                                </Border.GestureRecognizers>

                            </Border>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>


        <Border Grid.Row="2"
        BackgroundColor="#40C95A"
        StrokeThickness="0"
        Padding="10,15">

            <Border.Shadow>
                <Shadow Brush="Black"
                Opacity="0.08"
                Radius="10"
                Offset="0,-2" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*, *">

                <VerticalStackLayout Grid.Column="0"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUrokTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Уроки"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Профиль"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>


                <VerticalStackLayout Grid.Column="2"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStaticTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Статистика"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>


                <VerticalStackLayout Grid.Column="3"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSlovarTapped" />
                    </VerticalStackLayout.GestureRecognizers>


                    <Label Text="Словарь"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>



                <VerticalStackLayout Grid.Column="4"
                             Spacing="4"
                             HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDostigTapped" />
                    </VerticalStackLayout.GestureRecognizers>

                    <Label Text="Достижения"
                   FontSize="16"
                   TextColor="White"
                   HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="5" Spacing="4" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPovtorTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Повторение"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

            </Grid>

        </Border>

    </Grid>

</ContentPage>